{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Blitz",
  "version": "0.1.0",
  "identifier": "com.blitz.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Blitz",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      },
      "desktop": {
        "category": "Office"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "updater": {
    "active": true,
    "pubkey": "",
    "endpoints": [
      "https://github.com/marketingbybesic/blitz-todo/releases/latest/download/latest.json"
    ],
    "dialog": true,
    "windows": {
      "installMode": "passive"
    }
  }
}
